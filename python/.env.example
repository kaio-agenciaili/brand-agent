# Provedor do LLM: openai (GPT) ou anthropic (Claude)
LLM_PROVIDER=openai

# OpenAI (quando LLM_PROVIDER=openai) — chave: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Modelo opcional; por defeito gpt-4o
# OPENAI_MODEL=gpt-4o

# Anthropic (quando LLM_PROVIDER=anthropic) — chave: https://console.anthropic.com
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Serper (pesquisa web no benchmark) — https://serper.dev — opcional: sem chave, o benchmark infere concorrentes só com o LLM
SERPER_API_KEY=

# Origens extra para CORS (browser → FastAPI), separadas por vírgula — ex.: domínio próprio na Vercel
# CORS_EXTRA_ORIGINS=https://meu-dominio.com
